{
    "name": "ib-acp-ui",
    "displayName": "ACP UI",
    "description": "Agent Client Protocol (ACP) UI integration",
    "publisher": "irishbruse",
    "author": "Ethan Conneely",
    "version": "0.2.1",
    "icon": "icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/IrishBruse/vscode-acp-ui.git"
    },
    "engines": {
        "vscode": "^1.115.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "ACP UI",
            "properties": {
                "ib-acp-ui.agents": {
                    "type": "array",
                    "description": "ACP agent configurations. Each entry defines an agent subprocess to launch.",
                    "items": {
                        "type": "object",
                        "required": [
                            "name",
                            "command"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Display name for the agent."
                            },
                            "command": {
                                "type": "string",
                                "description": "Executable to spawn (e.g. 'npx', 'gemini', 'claude')."
                            },
                            "args": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "Arguments passed to the command."
                            },
                            "env": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                },
                                "description": "Extra environment variables for the agent process."
                            }
                        }
                    },
                    "default": [
                        {
                            "name": "Cursor",
                            "command": "agent",
                            "args": [
                                "acp"
                            ]
                        },
                        {
                            "name": "Gemini",
                            "command": "gemini",
                            "args": [
                                "--acp"
                            ]
                        }
                    ]
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "acpUiContainer",
                    "title": "ACP UI",
                    "icon": "media/acp-icon.svg"
                }
            ]
        },
        "views": {
            "acpUiContainer": [
                {
                    "id": "acpUiSessionsView",
                    "name": "Chats",
                    "type": "tree",
                    "icon": "media/acp-icon.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "ib-acp-ui.openChat",
                "title": "Open ACP UI",
                "icon": "$(comment-discussion)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.focusAcpUiSessions",
                "title": "Focus ACP UI Chats list",
                "shortTitle": "Focus Chats list",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.newAcpUiInEditor",
                "title": "New ACP UI Chat (Default Agent)",
                "shortTitle": "New in Editor",
                "icon": "$(add)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.newAcpUiInEditorPickAgent",
                "title": "New ACP UI Chat (Pick Agent)",
                "shortTitle": "Pick Agent",
                "icon": "$(chevron-down)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.refreshAcpUiSessions",
                "title": "Refresh ACP UI list",
                "shortTitle": "Refresh",
                "icon": "$(refresh)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.openAcpUiSession",
                "title": "Open ACP UI session",
                "shortTitle": "Open",
                "icon": "$(comment-discussion)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.deleteAcpUiSession",
                "title": "Delete ACP UI",
                "shortTitle": "Delete",
                "icon": "$(trash)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.renameAcpUiSession",
                "title": "Rename ACP UI",
                "shortTitle": "Rename",
                "icon": "$(edit)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp-ui.showAcpRpcLog",
                "title": "Show ACP RPC Log",
                "category": "IrishBruse ACP"
            }
        ],
        "menus": {
            "view/item/context": [
                {
                    "command": "ib-acp-ui.deleteAcpUiSession",
                    "when": "view == acpUiSessionsView && viewItem == session",
                    "group": "inline"
                },
                {
                    "command": "ib-acp-ui.renameAcpUiSession",
                    "when": "view == acpUiSessionsView && viewItem == session",
                    "group": "inline"
                }
            ],
            "view/title": [
                {
                    "command": "ib-acp-ui.newAcpUiInEditor",
                    "when": "view == acpUiSessionsView",
                    "group": "navigation"
                },
                {
                    "command": "ib-acp-ui.newAcpUiInEditorPickAgent",
                    "when": "view == acpUiSessionsView",
                    "group": "navigation"
                },
                {
                    "command": "ib-acp-ui.refreshAcpUiSessions",
                    "when": "view == acpUiSessionsView",
                    "group": "navigation"
                }
            ]
        },
        "keybindings": [
            {
                "command": "ib-acp-ui.renameAcpUiSession",
                "key": "f2",
                "when": "view == acpUiSessionsView && viewItem == session && listFocus"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build:webview": "vite build --config webview/acp-ui/vite.config.ts",
        "dev:standalone": "concurrently --names FE,BE --prefix-colors cyan,yellow 'vite --config standalone/vite.config.ts' 'tsx --watch standalone/server.ts'",
        "build": "npm run build:webview && node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "package": "npm run build:webview && node esbuild.mjs --production",
        "check": "tsc --noEmit && tsc --noEmit -p webview/acp-ui/tsconfig.json && tsc --noEmit -p standalone/tsconfig.json",
        "test": "vitest run",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "verify": "concurrently --names Build,Check,Test,Lint 'npm run build' 'npm run check' 'npm run test' 'npm run lint'",
        "publish:vscode": "bash scripts/publish.sh"
    },
    "dependencies": {
        "@agentclientprotocol/sdk": "^0.18.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@types/vscode": "^1.115.0",
        "@types/ws": "^8.18.0",
        "@vitejs/plugin-react": "^6.0.1",
        "@vscode/vsce": "^3.7.1",
        "concurrently": "^9.2.1",
        "esbuild": "^0.28.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.1",
        "vitest": "^4.1.0"
    }
}
