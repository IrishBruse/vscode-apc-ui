{
    "name": "ib-acp-ui",
    "displayName": "ACP UI",
    "description": "Agent Client Protocol (ACP) UI integration",
    "publisher": "irishbruse",
    "author": "Ethan Conneely",
    "version": "0.1.0",
    "license": "MIT",
    "engines": {
        "vscode": "^1.115.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "ACP UI",
            "properties": {
                "ib-acp.agents": {
                    "type": "array",
                    "description": "ACP agent configurations. Each entry defines an agent subprocess to launch.",
                    "items": {
                        "type": "object",
                        "required": [
                            "name",
                            "command"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Display name for the agent."
                            },
                            "command": {
                                "type": "string",
                                "description": "Executable to spawn (e.g. 'npx', 'gemini', 'claude')."
                            },
                            "args": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "Arguments passed to the command."
                            },
                            "env": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                },
                                "description": "Extra environment variables for the agent process."
                            }
                        }
                    },
                    "default": [
                        {
                            "name": "Cursor",
                            "command": "agent",
                            "args": [
                                "acp"
                            ]
                        },
                        {
                            "name": "Gemini",
                            "command": "gemini",
                            "args": [
                                "--acp"
                            ]
                        }
                    ]
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "ibChatContainer",
                    "title": "IB Chat",
                    "icon": "media/chat_icon.svg"
                }
            ]
        },
        "views": {
            "ibChatContainer": [
                {
                    "id": "ibChatSessionsView",
                    "name": "Chats",
                    "type": "tree",
                    "icon": "media/chat_icon.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "ib-acp.openChat",
                "title": "Open IB Chat",
                "icon": "$(comment-discussion)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp.focusIbChatSessions",
                "title": "Focus IB Chat Chats list",
                "shortTitle": "Focus Chats list",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp.newIbChatInEditor",
                "title": "New IB Chat in Editor",
                "shortTitle": "New in Editor",
                "icon": "$(add)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp.refreshIbChatSessions",
                "title": "Refresh IB Chat list",
                "shortTitle": "Refresh",
                "icon": "$(refresh)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp.openIbChatSession",
                "title": "Open IB Chat session",
                "shortTitle": "Open",
                "icon": "$(comment-discussion)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp.deleteIbChatSession",
                "title": "Delete IB Chat",
                "shortTitle": "Delete",
                "icon": "$(trash)",
                "category": "IrishBruse ACP"
            },
            {
                "command": "ib-acp.showAcpRpcLog",
                "title": "Show ACP RPC Log",
                "category": "IrishBruse ACP"
            }
        ],
        "menus": {
            "view/item/context": [
                {
                    "command": "ib-acp.deleteIbChatSession",
                    "when": "view == ibChatSessionsView && viewItem == session",
                    "group": "inline"
                }
            ],
            "view/title": [
                {
                    "command": "ib-acp.refreshIbChatSessions",
                    "when": "view == ibChatSessionsView",
                    "group": "navigation"
                },
                {
                    "command": "ib-acp.newIbChatInEditor",
                    "when": "view == ibChatSessionsView",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build:webview": "vite build --config webview/acp-ui/vite.config.ts",
        "dev:standalone": "concurrently --names FE,BE --prefix-colors cyan,yellow 'vite --config standalone/vite.config.ts' 'tsx --watch standalone/server.ts'",
        "build": "npm run build:webview && node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "package": "npm run build:webview && node esbuild.mjs --production",
        "check": "tsc --noEmit && tsc --noEmit -p webview/acp-ui/tsconfig.json && tsc --noEmit -p standalone/tsconfig.json",
        "test": "vitest run",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "verify": "concurrently --names Build,Check,Test,Lint 'npm run build' 'npm run check' 'npm run test' 'npm run lint'"
    },
    "dependencies": {
        "@agentclientprotocol/sdk": "^0.18.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@types/vscode": "^1.115.0",
        "@types/ws": "^8.18.0",
        "@vitejs/plugin-react": "^6.0.1",
        "@vscode/vsce": "^3.7.1",
        "concurrently": "^9.2.1",
        "esbuild": "^0.28.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.1",
        "vitest": "^4.1.0"
    }
}
